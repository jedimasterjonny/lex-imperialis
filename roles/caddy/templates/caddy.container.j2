[Unit]
Description=Caddy reverse proxy

[Container]
ContainerName=caddy
Image={{ caddy_image }}
Network=caddy.network
NoNewPrivileges=true
DropCapability=all
{# Only to bind the privileged 80/443; caddy needs nothing else. #}
AddCapability=NET_BIND_SERVICE
EnvironmentFile=/etc/caddy/env
PublishPort=80:80
PublishPort=443:443
PublishPort=443:443/udp
# :Z relabels the mount container_file_t on each (re)start — the path's policy
# default (httpd_config_t) is unreadable to container_t under enforcing SELinux, and
# an autorelabel resets it there; the recreate also re-labels snippets dropped here.
Volume=/etc/caddy:/etc/caddy:ro,Z
Volume=caddy-data:/data
Volume=caddy-config:/config
# Restart backstop against caddy's own 204 health endpoint (the localhost site in
# the Caddyfile), not the monitor — see the health convention in CLAUDE.md.
HealthCmd=curl -fsS http://localhost/
HealthInterval=5m
HealthTimeout=30s
HealthStartPeriod=30s
HealthRetries=3
HealthOnFailure=kill

[Service]
Restart=on-failure
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
