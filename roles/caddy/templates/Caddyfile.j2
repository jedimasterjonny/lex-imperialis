{% if caddy_cloudflare_api_token %}
{
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

{% endif %}
# Health endpoint, so the bare proxy is observable.
http://localhost {
	respond 204
}

# Public-facing roles register full site blocks as sites-public/<role>.caddy,
# each serving its own domains and certified through the global acme_dns. No
# matching files is a no-op.
import sites-public/*.caddy
{% if caddy_wildcard %}

# Backend roles register matcher + handle snippets as sites/<role>.caddy; the
# wildcard vhost keeps these service names off the public CT logs.
{% if caddy_cloudflare_api_token %}
*.{{ caddy_domain }} {
{% else %}
http://*.{{ caddy_domain }} {
{% endif %}
	import sites/*.caddy

	# Unmatched subdomains get an explicit 404, not Caddy's empty 200.
	handle {
		respond 404
	}
}
{% endif %}

# Foreign hosts (the bare IP, a stray Host header) match nothing above; answer
# 404 rather than Caddy's default empty 200. Host-less, so a managed site's
# auto HTTP->HTTPS redirect (host-matched) still wins over it.
http:// {
	respond 404
}
