# Managed by Ansible (prometheus role).
global:
  scrape_interval: 15s
{% if prometheus_alertmanager_targets %}

alerting:
  alertmanagers:
    - static_configs:
        - targets: {{ prometheus_alertmanager_targets | to_json }}

rule_files:
  - /etc/prometheus/rules/*.yml
{% endif %}

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: node
    static_configs:
      - targets: {{ prometheus_node_targets | to_json }}

  - job_name: cadvisor
    # cadvisor polls every 30s (its housekeeping interval), so scrape at the same
    # cadence rather than the global 15s and avoid storing each sample twice.
    scrape_interval: 30s
    static_configs:
      - targets: {{ prometheus_cadvisor_targets | to_json }}
    # The Docker-monitoring dashboard (grafana 15798) groups container series by a
    # `container` label; cadvisor labels them `name`, so mirror it at ingest.
    metric_relabel_configs:
      - source_labels: [name]
        target_label: container
{% if prometheus_probe_targets %}

  # Blackbox probes: each target is passed to the blackbox_exporter as ?target=, and
  # the scrape hits the exporter, not the target. Each entry carries its prober module
  # as __param_module, so the module is per target rather than per job. The
  # relabelling moves the URL into the target param and the instance label, then
  # rewrites __address__ to the exporter so the scrape lands there.
  - job_name: blackbox
    # Each scrape is a live probe (DNS + TLS + redirect-follow), so scrape at 60s,
    # not the global 15s: the probe alerts key off minutes to hours (probe_success
    # for 5m, cert expiry for 1h), so a faster cadence only hammers the targets for
    # no gain.
    scrape_interval: 60s
    metrics_path: /probe
    static_configs:
{% for group in prometheus_probe_targets %}
      - targets: {{ group.targets | to_json }}
        labels:
          __param_module: {{ group.module | to_json }}
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: {{ prometheus_blackbox_address }}
{% endif %}
{% if prometheus_alertmanager_targets %}

  - job_name: alertmanager
    static_configs:
      - targets: {{ prometheus_alertmanager_targets | to_json }}
{% endif %}
