# Managed by Ansible (prometheus role).
services:
  prometheus:
    image: {{ prometheus_image }}
    container_name: prometheus
    # Host network: the container resolves scrape targets and routes to them
    # exactly as the host does, and Prometheus serves on the host's :9090.
    network_mode: host
    # Prometheus reads its config, writes its TSDB, and serves HTTP — it needs no
    # Linux capabilities and never needs to escalate privilege, so drop every
    # capability and bar new ones even on the host network.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
{% for opt in prometheus_security_opt_extra %}
      - {{ opt }}
{% endfor %}
    restart: unless-stopped
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
    volumes:
      - {{ prometheus_project_dir }}/prometheus.yml:/etc/prometheus/prometheus.yml:ro
{% if prometheus_alertmanager_targets %}
      - {{ prometheus_project_dir }}/rules:/etc/prometheus/rules:ro
{% endif %}
      - {{ prometheus_data_dir }}:/prometheus
