#!/usr/bin/env bash
# {{ ansible_managed }}
# systemd ExecStopPost hook for wordpress-cron.service: record the run's outcome
# as a node_exporter textfile metric so Prometheus can alert when the 5-minute
# wp-cron run hard-fails or the timer stops firing — either silently stalls every
# scheduled post and task. systemd sets SERVICE_RESULT to "success" iff ExecStart
# exited 0.
set -euo pipefail

dir="{{ wordpress_textfile_dir }}"
success=0
[ "${SERVICE_RESULT:-}" = success ] && success=1

mkdir -p "$dir"
# Publish atomically: write a temp file the exporter's *.prom glob ignores, then
# rename it over the target so no scrape reads a half-written file. 0644 so the
# exporter's unprivileged user can read it.
tmp="$(mktemp "$dir/.wordpress-cron.prom.XXXXXX")"
cat >"$tmp" <<EOF
# HELP wordpress_cron_success Whether the last WordPress cron run succeeded (1) or failed (0).
# TYPE wordpress_cron_success gauge
wordpress_cron_success $success
# HELP wordpress_cron_last_run_timestamp_seconds Unix time the last WordPress cron run finished.
# TYPE wordpress_cron_last_run_timestamp_seconds gauge
wordpress_cron_last_run_timestamp_seconds $(date +%s)
EOF
chmod 0644 "$tmp"
mv "$tmp" "$dir/wordpress-cron.prom"
