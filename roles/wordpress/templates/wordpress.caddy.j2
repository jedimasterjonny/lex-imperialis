{% set scheme = '' if wordpress_tls else 'http://' %}
{{ wordpress_domains | map('regex_replace', '^', scheme) | join(', ') }} {
{% if wordpress_tls %}
	# HSTS only applies over HTTPS.
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
{% endif %}
	header X-Content-Type-Options nosniff
	header Referrer-Policy strict-origin-when-cross-origin
	header Permissions-Policy "camera=(), microphone=(), geolocation=(), browsing-topics=()"
	# Don't advertise the PHP version the upstream tacks on.
	header -X-Powered-By

	# readme.html and license.txt just broadcast the exact core version.
	@version_files path /readme.html /license.txt
	respond @version_files 404

	# Cache static assets for a year, deferred so it beats any Cache-Control the
	# upstream sets. WordPress ?ver=-busts its css/js and renames re-uploaded
	# media, so nothing served from a static URL goes stale.
	@static path *.css *.js *.svg *.ico *.gif *.png *.jpg *.jpeg *.webp *.avif *.woff *.woff2 *.ttf *.otf *.eot
	header @static {
		Cache-Control "public, max-age=31536000, immutable"
		defer
	}

	reverse_proxy wordpress:80
}
