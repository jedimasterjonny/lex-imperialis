MARIADB_ROOT_PASSWORD={{ wordpress_db_root_password }}
MARIADB_DATABASE={{ wordpress_db_name }}
MARIADB_USER={{ wordpress_db_user }}
MARIADB_PASSWORD={{ wordpress_db_password }}
# Run mariadb-upgrade automatically when the image major exceeds the data dir's,
# so a renovate mariadb bump migrates the system tables with no manual step.
MARIADB_AUTO_UPGRADE=1
# mariadbd's log timestamps and NOW()/CURRENT_TIMESTAMP follow TZ; set it so the
# database container stays on wordpress_timezone rather than UTC.
TZ={{ wordpress_timezone }}
