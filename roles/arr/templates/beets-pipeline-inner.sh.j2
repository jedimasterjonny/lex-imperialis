# {{ ansible_managed }}
# shellcheck shell=sh
set -eu
# A podman exec inherits umask 022, but the staged copy must land group-writable:
# importMode:Move removes each track from the staging dir as it moves it into the
# library, and that needs group write on the dir (lidarr shares only the arr group
# here). Match the fleet's UMASK=002 so the cp-created dirs are group-writable —
# otherwise the Move fails "access denied" and nothing imports.
umask 002
# The API key arrives via --env from /etc/arr/lidarr.env; empty => no key => phase 2
# skips lidarr. The lidarr URL is not a secret, so it is templated straight in.
KEY="${LIDARR__AUTH__APIKEY:-}"
URL="{{ arr_beets_lidarr_url }}"
CFG=/config/managed/pipeline-config.yaml
DL="{{ arr_beets_download_dir }}"
STAGING="{{ arr_beets_staging_dir }}"
QUAR="{{ arr_beets_quarantine_dir }}"
CAP={{ arr_beets_poke_cap }}
POKEDIR=/config/pipeline/pokes
SCREENED=/config/pipeline/screened
mkdir -p "$POKEDIR" "$SCREENED" "$STAGING" "$QUAR/lidarr-rejected"
# beets is a stateless tagger here — it owns no library. But `beet import` still needs
# a database, and beets resolves the path to a real file (:memory: is expanded, not
# honoured), so point it at a throwaway under /tmp and discard it every run: phase 1
# only reads it back within the same run to tell a match from a skip, and phase 2
# never touches it.
SCRATCHDB=/tmp/beets-pipeline.blb
rm -f "$SCRATCHDB"*                      # the .blb and any SQLite -journal/-wal sidecar
trap 'rm -f "$SCRATCHDB"*' EXIT
# Clear any copy left half-written by a crash mid-cp, so phase 2 never mistakes a
# stale ".partial" for a finished staged album. No match => the literal glob is a
# harmless no-op under rm -f.
rm -rf "$STAGING"/*.partial

# Ask lidarr to import a staged album with importMode:Move — lidarr moves the
# matched audio out of staging into the library, renaming and organising it, so only
# the staged copy is consumed and the original download keeps seeding. A 2xx means
# queued, not done (lidarr has no import callback) — the wrapper instead watches the
# staged copy empty of audio (imported(), below). jq builds the body so a path with a
# quote or backslash can't break the JSON. Returns 0 for a definitive response (2xx
# queued, or a 4xx that won't fix itself — bad key/request), which counts toward the
# give-up cap; returns 1 only for a transient failure (5xx or no connection), retried
# without counting.
trigger_lidarr() {
  [ -n "$KEY" ] || { echo "no lidarr key; not triggering $1"; return 1; }
  body="$(jq -nc --arg p "$1" '{name:"DownloadedAlbumsScan",path:$p,importMode:"Move"}')"
  code=$(curl -s -o /dev/null -w '%{http_code}' -X POST "$URL/api/v1/command" \
    -H "X-Api-Key: $KEY" -H 'Content-Type: application/json' -d "$body")
  case "$code" in
    2*) return 0 ;;
    4*) echo "lidarr rejected scan of $1 (HTTP $code)"; return 0 ;;
    *) echo "lidarr unreachable for $1 (HTTP $code); will retry"; return 1 ;;
  esac
}

# Has lidarr taken this staged album? Move import lifts the matched audio out of the
# staging copy and into the library, so the copy emptying of audio is the "did lidarr
# import it" signal (the scan's 2xx only means queued). Audio still present means
# lidarr has not taken it — either queued and not yet run, or a silent reject; the
# 10-minute gap to this check means a queued import has long finished, so leftover
# audio is a genuine reject, not an in-flight import. Any extras lidarr declines stay
# behind and trip the poke cap, sending the leftover copy to lidarr-rejected.
imported() {
  [ -z "$(find "$1" -type f \( \
    -iname '*.flac' -o -iname '*.mp3' -o -iname '*.m4a' -o -iname '*.m4b' \
    -o -iname '*.opus' -o -iname '*.ogg' -o -iname '*.oga' -o -iname '*.wav' \
    -o -iname '*.wma' -o -iname '*.aac' -o -iname '*.aif' -o -iname '*.aiff' \
    -o -iname '*.ape' -o -iname '*.wv' -o -iname '*.mpc' -o -iname '*.dsf' \
    -o -iname '*.dff' \) 2>/dev/null)" ]
}

# Can MusicBrainz serve matches right now? A connection failure (000) or a 5xx
# (maintenance/rate-limit) would make beets match nothing, so defer; a healthy
# server answers ws/2/ with a non-5xx status.
mb_reachable() {
  mbcode="$(curl -s -o /dev/null -m 10 -w '%{http_code}' https://musicbrainz.org/ws/2/ 2>/dev/null || true)"
  case "$mbcode" in
    ''|000|5*) return 1 ;;
    *) return 0 ;;
  esac
}

# 1) Screen each new download exactly once: copy it, tag the copy, and either stage
#    it for lidarr or quarantine it. The screened marker (kept while the download
#    seeds) stops re-processing; it never touches the original download. Skip the
#    whole phase when MusicBrainz can't match (see mb_reachable): otherwise every
#    album would match nothing and be quarantined as a false no-match, re-copied
#    each tick.
if [ -d "$DL" ]; then
  if mb_reachable; then
    for album in "$DL"/*/; do
      [ -d "$album" ] || continue        # glob matched nothing => literal, skip
      album="${album%/}"
      name="$(basename "$album")"
      [ -e "$SCREENED/$name" ] && continue
      # settled-download gate: any file touched within the window means it is still
      # arriving, so leave it for a later tick.
      if [ -n "$(find "$album" -type f -mmin "-{{ arr_beets_stable_minutes }}")" ]; then
        echo "unstable, skipping: $name"
        continue
      fi
      stage="$STAGING/$name"
      rm -rf "$stage" "$stage.partial"
      cp -r "$album" "$stage.partial"    # pristine copy; the download is never modified => keeps seeding
      mv "$stage.partial" "$stage"
      # Tag the COPY in place (quiet; a sub-threshold match skips and writes nothing).
      # MusicBrainz was reachable above, so a non-zero exit or an empty match here is
      # album-specific, not a transient outage — quarantine the copy either way. The
      # scratch DB records a match; querying it back tells a tagged copy from a skip.
      beet -c "$CFG" -l "$SCRATCHDB" import "$stage" || echo "import errored: $name"
      if beet -c "$CFG" -l "$SCRATCHDB" ls -p "path:$stage" | grep -q .; then
        echo "matched, staged: $name"    # phase 2 hands it to lidarr
      elif [ -e "$QUAR/$name" ]; then
        rm -rf "$stage"
        echo "quarantine target exists, dropped copy: $name"
      else
        mv "$stage" "$QUAR/$name"
        echo "quarantined (no match or error): $name"
      fi
      touch "$SCREENED/$name"
    done
  else
    echo "musicbrainz unreachable; deferring screening this tick"
  fi
  # Drop screened markers whose download is gone (torrent removed), so the set
  # tracks only what is still on disk. Independent of MusicBrainz, so it runs even
  # on a deferred tick.
  for marker in "$SCREENED"/*; do
    [ -e "$marker" ] || continue
    [ -d "$DL/$(basename "$marker")" ] || rm -f "$marker"
  done
fi

# 2) Drive each staged copy into lidarr. Once imported (lidarr moved its audio into
#    the library) drop the now-emptied staging dir. A 2xx that never empties the copy
#    is the silent-reject case (unmonitored artist, profile mismatch), and a 4xx is a
#    permanent error (bad key/request); both count toward the cap, then the leftover
#    copy goes to lidarr-rejected. A 5xx / no connection is transient — leave the
#    count and retry, never quarantine.
for stage in "$STAGING"/*/; do
  [ -d "$stage" ] || continue
  stage="${stage%/}"
  name="$(basename "$stage")"
  pokefile="$POKEDIR/$name"
  pokes=$(cat "$pokefile" 2>/dev/null || echo 0)
  # Treat an emptied copy as imported only after lidarr has been poked at least once:
  # imported() reads "no audio left", which is also true from the start for an album
  # whose audio uses an extension it does not list — poking first hands every album to
  # lidarr (which moves any format) before this branch can drop it.
  if [ "$pokes" -ge 1 ] && imported "$stage"; then
    rm -rf "$stage"
    rm -f "$pokefile"
    echo "imported: $name"
    continue
  fi
  if trigger_lidarr "$stage"; then
    pokes=$((pokes + 1))
    if [ "$pokes" -ge "$CAP" ]; then
      if [ -e "$QUAR/lidarr-rejected/$name" ]; then
        rm -rf "$stage"
        echo "lidarr-rejected target exists, dropped copy: $name"
      else
        mv "$stage" "$QUAR/lidarr-rejected/"
        echo "gave up after $pokes pokes => lidarr-rejected: $name"
      fi
      rm -f "$pokefile"
    else
      echo "$pokes" > "$pokefile"
      echo "poked $pokes/$CAP, awaiting import: $name"
    fi
  else
    echo "retry next tick (lidarr transient): $name"
  fi
done
