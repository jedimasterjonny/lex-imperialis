# {{ ansible_managed }}
# Per-download screening config (used via `beet -c`). beets matches each staged
# album copy against MusicBrainz, tags it in place, and records it in its OWN
# pipeline DB, separate from the standing library catalog. directory points at the
# staging area (where the tagged copies live); the DB and log live under
# /config/pipeline, the writable config volume, not the read-only /config/managed
# bind this file is mounted at.
directory: {{ arr_beets_staging_dir }}
library: /config/pipeline/pipeline.blb
# musicbrainz is the matcher (a plugin in beets 2.x — without it there are zero
# candidates and everything skips); chroma fingerprints to aid matching; scrub
# strips foreign tags before beets writes its own.
plugins: [musicbrainz, chroma, scrub]
# beets owns tags and filenames, so write is on but copy/move stay off: the wrapper
# already placed the copy in staging, beets tags it where it sits, and lidarr
# hardlinks it into the library. quiet auto-imports a strong match; a weaker one
# falls back to skip (writes nothing) and the wrapper quarantines the copy.
import:
  write: yes
  copy: no
  move: no
  quiet: yes
  quiet_fallback: skip
  log: /config/pipeline/import.log
# Rendered unquoted (beets needs numbers): only a strong MusicBrainz match auto-
# imports; the gap threshold keeps a near-tie from counting as strong.
match:
  strong_rec_thresh: {{ arr_beets_strong_rec_thresh }}
  rec_gap_thresh: {{ arr_beets_rec_gap_thresh }}
chroma:
  auto: yes
scrub:
  auto: yes
