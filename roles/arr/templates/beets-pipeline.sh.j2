#!/usr/bin/env bash
# {{ ansible_managed }}
# Screen each completed music download with beets, then hand matches to lidarr —
# without disturbing the seeding torrent. The loop runs inside the beets container
# so every path is /data/..., matching what lidarr sees.
#
# Per album: copy the pristine download into a staging area and tag the COPY with
# beets (metadata only — beets owns the tags), so the original keeps seeding intact;
# then trigger lidarr to MOVE the staged copy into the library, where lidarr owns
# the renaming and folder layout (renameTracks on). A no-match copy goes to
# quarantine for hand-processing; the original download is never modified or moved.
set -euo pipefail
# Skip cleanly if beets is down (a boot-time Persistent catch-up firing before the
# container is up, or beets deliberately stopped) — catch up on the next tick.
systemctl is-active --quiet beets.service || { echo "beets not running; skipping pipeline"; exit 0; }
# The lidarr API key comes from EnvironmentFile=-/etc/arr/lidarr.env (the same 0600
# file the lidarr container reads, rendered by "Deploy the Servarr API keys"). --env
# with no value passes it through from this process's environment, so the key never
# appears in the podman exec argv. -i forwards the redirected inner script as the
# inner shell's stdin (without it podman feeds /dev/null and the script silently
# no-ops). The inner script is POSIX sh (the beets image is Alpine/busybox, no bash),
# split into its own rendered template so the shellcheck-jinja hook analyses it.
podman exec -i --user abc --env LIDARR__AUTH__APIKEY beets sh -s < {{ arr_beets_pipeline_inner_script }}
