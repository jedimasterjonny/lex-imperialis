{% set scheme = '' if homepage_tls else 'http://' %}
{{ scheme }}{{ homepage_domain }} {
{% if homepage_tls %}
	# HSTS only applies over HTTPS. No includeSubDomains: this is the fleet apex,
	# so it would pin every sibling subdomain to HTTPS for a year.
	header Strict-Transport-Security "max-age=31536000"
{% endif %}
	header X-Content-Type-Options nosniff
	header Referrer-Policy strict-origin-when-cross-origin
	reverse_proxy homepage:3000
}
