{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":semanticCommits", ":automergeMinor"],
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["pin", "pinDigest"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchUpdateTypes": ["major"],
      "reviewers": ["jedimasterjonny"],
      "addLabels": ["claude-review"]
    },
    {
      "matchDepNames": ["python"],
      "matchUpdateTypes": ["minor"],
      "automerge": false
    }
  ]
}
