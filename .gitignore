# Python virtualenv
.venv/

# Python bytecode
__pycache__/
*.py[cod]

# Ansible retry files (can leak hostnames)
*.retry

# Ansible-lint cache
.ansible/

# Vault password file
.vault_pass

# OpenTofu/Terraform (state and *.tfvars hold secrets; .terraform.lock.hcl is committed)
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
# Saved plan the terraform workflow writes (tofu -chdir=terraform plan -out=tfplan)
tfplan
crash.log
crash.*.log

# Hugo (jonnyoc-site)
/jonnyoc-site/public/
/jonnyoc-site/resources/_gen/
.hugo_build.lock
.firebase/

# Claude Code local state (.claude/skills is tracked, so no blanket ignore)
/.claude/settings.local.json
/.claude/scheduled_tasks.*
/.claude/worktrees/
