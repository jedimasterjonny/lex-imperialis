# Activate the project venv on entering the directory.
if [ -f .venv/bin/activate ]; then
  export VIRTUAL_ENV="${PWD}/.venv"
  PATH_add "$VIRTUAL_ENV/bin"
else
  log_status ".venv not found — run 'python -m venv .venv && pip install -r requirements-dev.txt'"
fi

# Ansible looks up collections under ~/.ansible/collections only.
#
# We deliberately do NOT include ${PWD}/collections here. The in-repo collection
# source lives at ${PWD}/collections/ansible_collections/jedimasterjonny/lex/,
# and molecule/ansible-compat will silently `ansible-galaxy collection install .`
# into the first writable path on this var — which, if it were ${PWD}/collections,
# would wipe the source. Keep this var pointing at the home install path only;
# `make setup` installs deps and the project collection there.
export ANSIBLE_COLLECTIONS_PATH="${HOME}/.ansible/collections"

# Set ANSIBLE_CONFIG explicitly so child processes find it even from subdirs.
export ANSIBLE_CONFIG="${PWD}/ansible.cfg"
