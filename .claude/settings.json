{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(git ls-files*)",
      "Bash(git worktree list*)",
      "Bash(git remote -v)",
      "Bash(git remote show*)",
      "Bash(git config --get*)",

      "Bash(git add *)",
      "Bash(git restore --staged *)",
      "Bash(git stash*)",

      "Bash(ls)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(pwd)",
      "Bash(which *)",

      "Bash(make help)",
      "Bash(make lint)",
      "Bash(make lint-yaml)",
      "Bash(make lint-ansible)",
      "Bash(yamllint*)",
      "Bash(ansible-lint*)",
      "Bash(pre-commit run*)",

      "Bash(ansible --version)",
      "Bash(ansible-playbook --version)",
      "Bash(ansible-galaxy --version)",
      "Bash(ansible-galaxy collection list*)",
      "Bash(ansible-config dump*)",
      "Bash(ansible-config list*)",
      "Bash(ansible-config view*)",
      "Bash(ansible-doc *)",
      "Bash(ansible-inventory --list*)",
      "Bash(ansible-inventory --graph*)",

      "Bash(antsibull-changelog lint*)",
      "Bash(antsibull-changelog generate*)",
      "Bash(antsibull-changelog release*)",

      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(pip freeze*)",
      "Bash(pip install -r requirements-dev.txt)",

      "Bash(direnv status)",
      "Bash(direnv exec *)",

      "Bash(gh repo view*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh auth status)"
    ],
    "deny": [
      "Bash(git add -A)",
      "Bash(git add -A *)",
      "Bash(git add .)",
      "Bash(git add . *)"
    ]
  }
}
