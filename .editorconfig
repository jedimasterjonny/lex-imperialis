root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

# Caddyfile templates and PHP keep their ecosystems' tab convention (caddy fmt
# emits tabs; WordPress coding standards mandate them). Everything else — shell
# included — is spaces, per [*] above.
[{Caddyfile.j2,*.caddy.j2,*.php}]
indent_style = tab
